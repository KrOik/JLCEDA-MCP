[
  {
    "name": "jlceda_api_search",
    "description": "通过桥接在 EDA 侧离线 API 文档中检索嘉立创 EDA API。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "检索关键词，支持 API 名称、摘要、命名空间等。建议使用英文关键词（如 bom、getDrc、place 等），可组合多词（空格分隔）。"
        },
        "scope": {
          "type": "string",
          "enum": [
            "all",
            "callable",
            "type"
          ],
          "default": "all",
          "description": "检索范围：all=全部，callable=可调用 API，type=类型符号。查找可调用函数时优先使用 callable。"
        },
        "owner": {
          "type": "string",
          "description": "可选。按所属命名空间/类型过滤，能大幅缩小结果范围。当前文档为原理图时，使用 \"sch\" 过滤原理图专属 API；为 PCB 时，使用 \"pcb\" 过滤 PCB 专属 API。示例：owner=\"sch\" 可找到 eda.sch_ManufactureData 等原理图命名空间下的 API。"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 10,
          "description": "最多返回条数，范围 1-50。"
        }
      },
      "required": [
        "query"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "jlceda_api_invoke",
    "description": "通过桥接队列请求 EDA 扩展进程执行指定 API。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "apiFullName": {
          "type": "string",
          "description": "要调用的 API 全名。"
        },
        "args": {
          "type": "array",
          "items": {},
          "description": "API 调用参数列表，严格按 signatureText 中的参数顺序填写。无入参时传空数组 []。"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      },
      "required": [
        "apiFullName"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "jlceda_context_get",
    "description": "获取 EDA 运行时上下文快照（工程、文档、选区等）。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "description": "可选。上下文读取范围标识。"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      },
      "additionalProperties": false
    }
  },
  {
    "name": "jlceda_schematic_check",
    "description": "对当前原理图执行完整检查：ERC 电气规则检查 + 构建器件布局图（含每个器件的位号、坐标、旋转、镜像、封装，及每个引脚的名称、编号、类型、坐标、方向、引脚长度、连接状态），返回 ERC 结果与器件布局图供 AI 分析。无需传入任何参数。",
    "inputSchema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    }
  },
  {
    "name": "component_select",
    "description": "在 EDA 系统库中搜索候选器件，并在 VS Code 左侧边栏中显示交互选型面板；工具会等待用户确认或取消后，再返回最终选型结果。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "keyword": {
          "type": "string",
          "description": "器件搜索关键词（必填）。关键词必须使用空格分隔，优先使用常用简称 + 封装/大小 + 关键参数。"
        },
        "limit": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20,
          "default": 20,
          "description": "返回候选数量上限，范围 2-20，默认 20。"
        }
      },
      "required": [
        "keyword"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "component_place",
    "description": "校验已确认好的器件列表，并在 VS Code 左侧边栏中显示交互放置面板；工具会等待用户启动并完成放置流程后，再返回最终放置结果。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "components": {
          "type": "array",
          "description": "待放置器件数组（必填），按最终放置顺序排列。每项必须提供 uuid 和 libraryUuid。",
          "items": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "description": "器件 UUID。"
              },
              "libraryUuid": {
                "type": "string",
                "description": "器件所属库 UUID。"
              },
              "name": {
                "type": "string",
                "description": "器件名称（可选）。"
              },
              "footprintName": {
                "type": "string",
                "description": "封装名称（可选）。"
              },
              "subPartName": {
                "type": "string",
                "description": "多子部件器件的子部件名称（可选）。"
              }
            },
            "required": [
              "uuid",
              "libraryUuid"
            ],
            "additionalProperties": false
          }
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 180,
          "default": 60,
          "description": "单个器件放置超时时间，单位秒，范围 30-180，默认 60。"
        }
      },
      "required": [
        "components"
      ],
      "additionalProperties": false
    }
  }
]
