[
  {
    "name": "api_index",
    "description": "获取可调用 EDA API 索引列表。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string",
          "description": "可选。按命名空间过滤，例如 sch/dmt/lib，不填则返回全部。"
        }
      }
    }
  },
  {
    "name": "api_search",
    "description": "搜索 EDA API 签名与说明信息。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "检索关键词，支持 API 名称、摘要、命名空间等。建议使用英文关键词（如 bom、getDrc、place 等），可组合多词（空格分隔）。"
        },
        "scope": {
          "type": "string",
          "enum": [
            "all",
            "callable",
            "type"
          ],
          "default": "all",
          "description": "检索范围：all=全部，callable=可调用 API，type=类型符号。查找可调用函数时优先使用 callable。"
        },
        "owner": {
          "type": "string",
          "description": "可选。按所属命名空间/类型过滤，能大幅缩小结果范围。当前文档为原理图时，使用 \"sch\" 过滤原理图专属 API；为 PCB 时，使用 \"pcb\" 过滤 PCB 专属 API。示例：owner=\"sch\" 可找到 eda.sch_ManufactureData 等原理图命名空间下的 API。"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 10,
          "description": "最多返回条数，范围 1-50。"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  {
    "name": "api_invoke",
    "description": "调用指定的 EDA API 接口。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "apiFullName": {
          "type": "string",
          "description": "要调用的 API 全名，格式为 eda.模块名.方法名（最少三段路径），例如 eda.sch_Drc.check。"
        },
        "args": {
          "type": "array",
          "items": {},
          "description": "API 调用参数列表，严格按 signatureText 中的参数顺序填写。无入参时传空数组 []。"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      },
      "required": [
        "apiFullName"
      ]
    }
  },
  {
    "name": "eda_context",
    "description": "获取当前 EDA 运行时上下文信息。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "description": "可选。上下文读取范围标识，用于业务侧分组标记，可传入任意字符串或不传。"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      }
    }
  },
  {
    "name": "schematic_read",
    "description": "读取当前原理图页面的完整电路语义快照。",
    "inputSchema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "schematic_review",
    "description": "读取全工程所有原理图页面的网表文件。",
    "inputSchema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "pcb_snapshot",
    "description": "读取当前 PCB 页面归一化后的几何关系快照。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "nets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。按网络名过滤返回对象。"
        },
        "layerIds": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "可选。按图层 ID 过滤返回对象。"
        },
        "include": {
          "type": "object",
          "description": "可选。控制返回的对象族，未指定时默认全部开启。",
          "properties": {
            "lines": {
              "type": "boolean"
            },
            "arcs": {
              "type": "boolean"
            },
            "vias": {
              "type": "boolean"
            },
            "pours": {
              "type": "boolean"
            },
            "fills": {
              "type": "boolean"
            },
            "regions": {
              "type": "boolean"
            },
            "images": {
              "type": "boolean"
            },
            "objects": {
              "type": "boolean"
            },
            "components": {
              "type": "boolean"
            },
            "pads": {
              "type": "boolean"
            },
            "boardOutline": {
              "type": "boolean"
            },
            "layers": {
              "type": "boolean"
            }
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      }
    }
  },
  {
    "name": "pcb_geometry_analyze",
    "description": "分析当前 PCB 的几何关系并返回规范化特征与证据。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "nets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。仅分析这些网络。"
        },
        "layerIds": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "可选。仅分析这些图层上的对象。"
        },
        "tracePrimitiveIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。仅分析指定走线/圆弧图元。"
        },
        "referenceNetNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。参考网络名列表，默认使用常见地网络。"
        },
        "analysisModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "net_stats",
              "reference_grounding",
              "board_edge_clearance",
              "return_via_clearance",
              "plane_connectivity",
              "loop_area_proxy",
              "spatial_relations"
            ]
          },
          "description": "可选。分析模式列表，默认执行全部模式。"
        },
        "spatialObjectKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pour",
              "fill",
              "region",
              "image",
              "object"
            ]
          },
          "description": "可选。空间关系分析时纳入计算的对象族，默认包含 pour/fill/region/image/object。"
        },
        "sampleStep": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 8,
          "description": "采样步长，单位继承当前 EDA 原生坐标系。"
        },
        "includeSnapshot": {
          "type": "boolean",
          "default": false,
          "description": "是否在分析结果中附带归一化快照。"
        },
        "include": {
          "type": "object",
          "description": "可选。控制分析前加载的对象族，未指定时默认全部开启。",
          "properties": {
            "lines": {
              "type": "boolean"
            },
            "arcs": {
              "type": "boolean"
            },
            "vias": {
              "type": "boolean"
            },
            "pours": {
              "type": "boolean"
            },
            "fills": {
              "type": "boolean"
            },
            "regions": {
              "type": "boolean"
            },
            "images": {
              "type": "boolean"
            },
            "objects": {
              "type": "boolean"
            },
            "components": {
              "type": "boolean"
            },
            "pads": {
              "type": "boolean"
            },
            "boardOutline": {
              "type": "boolean"
            },
            "layers": {
              "type": "boolean"
            }
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      }
    }
  },
  {
    "name": "pcb_constraint_snapshot",
    "description": "读取当前 PCB 的第二层约束与结构上下文快照，包括规则配置、差分对、等长组、网络类以及更细的 pad/via 结构细节。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "nets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。按网络名过滤差分对、等长组、网络类以及 pad/via 条目。"
        },
        "viaPrimitiveIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。仅返回这些 via 图元。"
        },
        "padPrimitiveIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "可选。仅返回这些 pad 图元。"
        },
        "include": {
          "type": "object",
          "description": "可选。控制返回的第二层对象族，未指定时默认全部开启。",
          "properties": {
            "ruleConfiguration": {
              "type": "boolean"
            },
            "netRules": {
              "type": "boolean"
            },
            "netByNetRules": {
              "type": "boolean"
            },
            "regionRules": {
              "type": "boolean"
            },
            "differentialPairs": {
              "type": "boolean"
            },
            "equalLengthNetGroups": {
              "type": "boolean"
            },
            "netClasses": {
              "type": "boolean"
            },
            "padPairGroups": {
              "type": "boolean"
            },
            "vias": {
              "type": "boolean"
            },
            "pads": {
              "type": "boolean"
            }
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000,
          "default": 15000,
          "description": "桥接超时（毫秒）。"
        }
      }
    }
  },
  {
    "name": "component_select",
    "description": "搜索器件候选项并返回确认结果。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "keyword": {
          "type": "string",
          "description": "器件搜索关键词（必填）。"
        },
        "limit": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20,
          "default": 20,
          "description": "返回候选数量上限，范围 2-20，默认 20。"
        }
      },
      "required": [
        "keyword"
      ]
    }
  },
  {
    "name": "component_place",
    "description": "引导放置已确认的器件列表。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "components": {
          "type": "array",
          "description": "待放置器件数组（必填），按最终放置顺序排列。每个器件必须提供 uuid 和 libraryUuid。",
          "items": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "description": "器件 UUID（必填）。"
              },
              "libraryUuid": {
                "type": "string",
                "description": "器件所属库 UUID（必填）。"
              },
              "name": {
                "type": "string",
                "description": "器件名称（可选）。"
              },
              "footprintName": {
                "type": "string",
                "description": "封装名称（可选）。"
              },
              "subPartName": {
                "type": "string",
                "description": "多子部件器件的子部件名称（可选）。"
              }
            }
          }
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 180,
          "default": 60,
          "description": "单个器件放置超时时间，单位秒，范围 30-180，默认 60。"
        }
      },
      "required": [
        "components"
      ]
    }
  }
]
