{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCP Hub",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/mcp-hub"
      ],
      "outFiles": [
        "${workspaceFolder}/mcp-hub/out/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}