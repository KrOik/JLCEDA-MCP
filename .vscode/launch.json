{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run JLC MCP Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/mcp-server"
      ],
      "outFiles": [
        "${workspaceFolder}/mcp-server/out/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}